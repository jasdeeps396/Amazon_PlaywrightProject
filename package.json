  "type": "commonjs",
  "dependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-playwright": "^3.6.0",
    "multiple-cucumber-html-reporter": "^3.10.0"
  }
}
